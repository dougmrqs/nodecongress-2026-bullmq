{
  "name": "nodecongress-2026-bullmq",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "dev": "tsx watch src/index.ts",
    "dev:registration": "tsx watch registration-server/src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "tsx src/index.ts",
    "start:registration": "tsx registration-server/src/index.ts",
    "format": "prettier --write .",
    "lint": "eslint src/",
    "lint:registration": "eslint registration-server/src/",
    "typecheck": "tsc --noEmit",
    "typecheck:registration": "tsc --noEmit -p registration-server/tsconfig.json"
  },
  "dependencies": {
    "@bull-board/fastify": "^6.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "bullmq": "^5.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@faker-js/faker": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
